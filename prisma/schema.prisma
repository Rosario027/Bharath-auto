// Bharath Automation — Invoicing database schema
// Postgres on Railway. `prisma migrate deploy` runs on boot.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ──────────────────────────────────────────────────────────────
// Company settings — the "fixed components" of every invoice.
// Singleton row (id = 1). Edited in the Settings pane and reflected
// live across the dashboard, preview and all exports.
// ──────────────────────────────────────────────────────────────
model CompanySettings {
  id           Int      @id @default(1)

  companyName  String   @default("Bharath Automation")
  tagline      String   @default("")
  logoDataUrl  String?  // optional uploaded logo (data URL). Falls back to built-in mark.

  // Address & contact (the block that prints under the logo)
  addressLines String[] @default([])
  phones       String[] @default([])
  emails       String[] @default([])
  website      String   @default("")
  gstn         String   @default("")
  division     String   @default("")
  stateCode    String   @default("33") // for intra/inter-state GST detection (TN = 33)

  // Invoice document defaults
  invoiceTitle   String  @default("Commercial Invoice")
  invoiceCopy    String  @default("Original for Buyer")
  invoicePrefix  String  @default("BA/TR/PS-")
  nextInvoiceSeq Int     @default(22)

  // Tax defaults
  defaultCgst    Float @default(9)
  defaultSgst    Float @default(9)
  defaultIgst    Float @default(18)
  defaultGstRate Float @default(18) // default total GST % applied to new line items

  // Footer / terms
  paymentTerms String  @default("Immediate.")
  bankName     String  @default("")
  bankAccount  String  @default("")
  bankIfsc     String  @default("")
  bankBranch   String  @default("")
  footerNote   String  @default("E & O.E")
  signatory    String  @default("Authorized Signatory")
  signatureDataUrl String?
  termsNote    String  @default("Goods once sold will not be taken back. Subject to Coimbatore jurisdiction.")

  // Presentation
  defaultTheme String  @default("orange")
  currency     String  @default("INR")
  currencySymbol String @default("₹")

  // Login screen content (editable by admin, shown to everyone)
  loginNote   String  @default("")
  loginHeading String @default("Thirukural of the day")
  showLoginQuote Boolean @default(true)

  updatedAt DateTime @updatedAt
}

// App users (login accounts). Passwords are scrypt-hashed.
model User {
  id        Int       @id @default(autoincrement())
  username  String    @unique
  role      String    @default("user") // admin | user (accountant) | staff
  perms     String    @default("") // JSON {module: 'none'|'user'|'full'} — admin grants per-module access
  passHash  String
  createdAt DateTime  @default(now())
  employee  Employee?
}

// Bank transactions awaiting / done with categorization (AR-AP mapping).
model BankTxn {
  id            Int      @id @default(autoincrement())
  bankLedgerId  Int
  date          String
  description   String   @default("")
  debit         Float    @default(0) // out of bank
  credit        Float    @default(0) // into bank
  status        String   @default("pending") // pending | categorized | partial (excess parked in To Be Verified)
  voucherId     Int?
  categorizedAs String   @default("")
  invoiceId     Int?     // AR: mapped sales invoice
  billVoucherId Int?     // AP: mapped purchase bill (AccVoucher of vtype purchase)
  appliedAmount Float    @default(0) // portion settled against the invoice/bill
  byUsername    String   @default("")
  createdAt     DateTime @default(now())
}

// Staff request to add/fix attendance for a missed day — admin approves.
model AttendanceRequest {
  id           Int      @id @default(autoincrement())
  employeeId   Int
  employee     Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  date         String   // yyyy-mm-dd
  workSummary  String   @default("")
  status       String   @default("pending") // pending | approved | rejected
  adminComment String   @default("")
  createdAt    DateTime @default(now())

  @@unique([employeeId, date])
}

// Staff / employee files
model Employee {
  id               Int       @id @default(autoincrement())
  userId           Int?      @unique
  user             User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  name             String
  dob              DateTime?
  address          String    @default("")
  phone            String    @default("")
  altPhone         String    @default("")
  bloodGroup       String    @default("")
  medicalCondition String    @default("")
  medication       String    @default("")
  emergencyName    String    @default("") // parent / guardian
  emergencyPhone   String    @default("")
  email            String    @default("")
  // documents — stored as image data URLs (<= 2MB each)
  aadharDoc    String?
  panDoc       String?
  licenseDoc   String?
  rcDoc        String?
  insuranceDoc String?
  // vehicle
  vehicleNo       String    @default("")
  insuranceExpiry DateTime?
  // Compensation (admin-controlled; salary auto-computed from attendance)
  monthlySalary Float   @default(0)
  satOff        Boolean @default(false) // Saturday is a weekly off
  sunOff        Boolean @default(true)  // Sunday is a weekly off
  sunMultiplier Float   @default(2)     // pay multiplier when working on an off-day
  active          Boolean   @default(true)

  // Extended profile fields (BRD §4.1)
  photoUrl        String?   // individual photograph (data URL)
  familyPhotoUrl  String?   // family group photograph (data URL)
  insuranceDocs   String[]  @default([]) // array of data URLs
  academicDocs    String[]  @default([]) // mark sheets, certs, degrees (data URLs)

  // Address details
  permanentAddress String   @default("")
  currentAddress   String   @default("")
  familyLocationAddress String @default("")
  familyLocationLat Float?
  familyLocationLng Float?

  // Talent origin sourcing
  referredByType       String  @default("") // walk-in | campus | referral
  referredByEmployeeId Int?    // valid Employee.id when referredByType = referral

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  attendance      Attendance[]
  leaves          LeaveRequest[]
  expenses        ExpenseClaim[]
  tasks           StaffTask[]
  siteVisits      SiteVisit[]
  attendanceRequests AttendanceRequest[]
  goals           StaffGoal[]
  businessAssets  BusinessAsset[]
  deadlineRequests TaskDeadlineRequest[]
}

// ──────────────────────────────────────────────────────────────
// Site visits — replaces the manual "Site Visits.xlsx" sheet.
// The master record holds the latest state; every submission
// (first visit or any follow-up) is stored as a SiteVisitUpdate
// "tranche" so admin sees the full history with timestamps.
// ──────────────────────────────────────────────────────────────
model SiteVisit {
  id         Int       @id @default(autoincrement())
  refNo      String    @unique @default("") // SV-0001 …
  siteName   String    @default("") // friendly name to find the visit later
  employeeId Int?      // current assignee (sales executive)
  employee   Employee? @relation(fields: [employeeId], references: [id], onDelete: SetNull)
  createdBy  String    @default("")

  // Visit
  visitDate String @default("") // yyyy-mm-dd (first visit)

  // Customer
  customerName  String @default("")
  contactPerson String @default("")
  contactPhone  String @default("")
  altPhone      String @default("")

  // Location
  googleLocation String @default("") // GPS / maps link
  address        String @default("")
  district       String @default("")
  buildingSize   String @default("")

  // Architect / Interior / Civil Engineer
  proType  String @default("") // Ar | Ir | Civil Er
  proName  String @default("")
  proPhone String @default("")

  // Builder & contractor
  builderName          String @default("")
  builderPhone         String @default("")
  electricalContractor String @default("")

  // Visit category (BRD §2.1 split)
  visitCategory String @default("lead_visit") // project_visit | lead_visit

  // Lead & requirement
  leadSource         String @default("")
  projectType        String @default("")
  requirementSummary String @default("")
  productsDiscussed  String @default("")
  homeTheatre        String @default("") // Yes | No (legacy, kept for migration)

  // Dynamic item checklist (JSON array of {itemId, itemName, checked})
  itemsChecklist String @default("[]")
  othersNote     String @default("") // free-text when 'Others' is checked

  // Resource allocation (BRD §2.2)
  siteVisitLeads    String @default("[]") // JSON array of employee ids/names
  technicalPersonnel String @default("[]") // JSON array of employee ids/names

  // Key person details (BRD §2.2) — bubbles up to Customer
  keyPersonName  String @default("")
  keyPersonRole  String @default("") // Business Owner | MD | Architect …
  keyPersonPhone String @default("")

  // Lead visit specific (BRD §2.1)
  dimensions        String @default("") // preliminary site dimensions
  estimatedCost     Float  @default(0)
  siteEvaluation    String @default("")

  // Sales pipeline (latest state — synced from the newest tranche)
  visitType      String  @default("new") // new | follow up
  status         String  @default("assigned") // assigned | open | follow-up | closed
  quotationNo    String  @default("")
  quotationValue Float   @default(0)
  nextFollowUp   String  @default("") // yyyy-mm-dd
  whoIsFollowing String  @default("")
  probability    Float   @default(0) // %
  remarks        String  @default("")

  updates SiteVisitUpdate[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// One tranche = one field submission (initial visit or follow-up round).
model SiteVisitUpdate {
  id          Int       @id @default(autoincrement())
  siteVisitId Int
  siteVisit   SiteVisit @relation(fields: [siteVisitId], references: [id], onDelete: Cascade)
  tranche     Int       @default(1)
  byUsername  String    @default("")

  visitDate         String @default("")
  visitType         String @default("")
  status            String @default("")
  productsDiscussed String @default("")
  quotationNo       String @default("")
  quotationValue    Float  @default(0)
  nextFollowUp      String @default("")
  whoIsFollowing    String @default("")
  probability       Float  @default(0)
  summary           String @default("") // what happened on this visit / remarks

  createdAt DateTime @default(now())
}

model Attendance {
  id          Int       @id @default(autoincrement())
  employeeId  Int
  employee    Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  date        String    // yyyy-mm-dd
  present     Boolean   @default(true)
  clockIn     DateTime?
  clockOut    DateTime?
  workSummary String    @default("") // mandatory brief of the day's work (on clock-out / full-day)
  manual      Boolean   @default(false) // true when marked as full-day without clock in/out

  @@unique([employeeId, date])
}

// Staff leave requests — staff raise, admin approves/rejects.
model LeaveRequest {
  id           Int      @id @default(autoincrement())
  employeeId   Int
  employee     Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  fromDate     String   // yyyy-mm-dd
  toDate       String   // yyyy-mm-dd
  reason       String   @default("")
  status       String   @default("pending") // pending | approved | rejected
  adminComment String   @default("")
  createdAt    DateTime @default(now())
}

// Staff expense claims (travel etc.) with an optional receipt image (<= 2MB).
model ExpenseClaim {
  id           Int      @id @default(autoincrement())
  employeeId   Int
  employee     Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  date         String   // yyyy-mm-dd
  category     String   @default("Travel")
  amount       Float    @default(0)
  description  String   @default("")
  receipt      String?  // image data URL, <= 2MB
  status       String   @default("pending") // pending | approved | rejected
  adminComment String   @default("")
  createdAt    DateTime @default(now())
}

// Tasks assigned by admin to a staff member.
model StaffTask {
  id           Int       @id @default(autoincrement())
  employeeId   Int?      // null = admin's own task
  employee     Employee? @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  title        String
  description  String    @default("")
  dueDate      String?   // yyyy-mm-dd
  priority     String    @default("medium") // low | medium | high
  status       String    @default("assigned") // assigned | processing | completed | pending_deadline_approval
  staffComment String    @default("")
  assignedBy   String    @default("Admin")
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deadlineRequests TaskDeadlineRequest[]
}

// ──────────────────────────────────────────────────────────────
// ACCOUNTING MODULE — Indian double-entry books (Tally-style).
// Groups → Ledgers → Vouchers (balanced Dr/Cr lines). Every voucher
// edit is journaled (MCA Companies (Accounts) Rules, Rule 11(g)
// audit-trail requirement). Invoices/CN/DN auto-post here.
// ──────────────────────────────────────────────────────────────
model AccGroup {
  id       Int    @id @default(autoincrement())
  name     String @unique
  nature   String // asset | liability | income | expense
  parent   String @default("") // e.g. "Current Assets"
  isSystem Boolean @default(true)
  ledgers  AccLedger[]
}

model AccLedger {
  id             Int      @id @default(autoincrement())
  name           String   @unique
  groupId        Int
  group          AccGroup @relation(fields: [groupId], references: [id])
  openingBalance Float    @default(0) // amount (₹)
  openingType    String   @default("dr") // dr | cr
  gstin          String   @default("")
  notes          String   @default("")
  isSystem       Boolean  @default(false) // seeded core ledgers can't be deleted
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  lines          AccVoucherLine[]
}

model AccVoucher {
  id              Int      @id @default(autoincrement())
  voucherNo       String   // per-type sequence, e.g. JV-0001
  vtype           String   // sales | purchase | payment | receipt | contra | journal | credit-note | debit-note
  date            String   // yyyy-mm-dd
  narration       String   @default("")
  refNo           String   @default("") // bill / invoice reference
  sourceInvoiceId Int?     @unique // auto-posted from the invoicing module
  createdBy       String   @default("")
  editCount       Int      @default(0)
  lines           AccVoucherLine[]
  edits           AccVoucherEdit[]
  rmaTicket       RmaTicket?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model AccVoucherLine {
  id        Int        @id @default(autoincrement())
  voucherId Int
  voucher   AccVoucher @relation(fields: [voucherId], references: [id], onDelete: Cascade)
  ledgerId  Int
  ledger    AccLedger  @relation(fields: [ledgerId], references: [id])
  debit     Float      @default(0)
  credit    Float      @default(0)
  sortOrder Int        @default(0)
}

// MCA audit trail — append-only change log per voucher.
model AccVoucherEdit {
  id         Int        @id @default(autoincrement())
  voucherId  Int
  voucher    AccVoucher @relation(fields: [voucherId], references: [id], onDelete: Cascade)
  byUsername String     @default("")
  summary    String
  changedAt  DateTime   @default(now())
}

// Fixed asset register → depreciation schedule (WDV / SLM).
model FixedAsset {
  id             Int      @id @default(autoincrement())
  name           String
  category       String   @default("Plant & Machinery")
  purchaseDate   String   @default("") // yyyy-mm-dd
  cost           Float    @default(0)  // gross block
  additions      Float    @default(0)  // additions during the year
  accumulatedDep Float    @default(0)  // opening accumulated depreciation
  depRate        Float    @default(15) // % per annum
  method         String   @default("WDV") // WDV | SLM
  notes          String   @default("")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

// Rotating login-screen quotes (Thirukkural). One is shown per day,
// deterministically, so every user sees the same quote that day.
model LoginQuote {
  id        Int      @id @default(autoincrement())
  text      String   // couplet — two lines separated by \n
  meaning   String   @default("")
  active    Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
}

// ──────────────────────────────────────────────────────────────
// Saved customers (optional reuse / autofill)
// ──────────────────────────────────────────────────────────────
// ──────────────────────────────────────────────────────────────
// Invoice number series. Multiple series can exist (e.g. per division
// or year); each keeps its own running sequence. The next number is
// auto-generated and never reused, even if an invoice is deleted.
// ──────────────────────────────────────────────────────────────
model InvoiceSeries {
  id        Int      @id @default(autoincrement())
  name      String   @default("Default")
  prefix    String   @default("BA/TR/PS-")
  nextSeq   Int      @default(1)
  padWidth  Int      @default(4)
  isDefault Boolean  @default(false)
  docType   String   @default("invoice") // invoice | credit-note | debit-note
  createdAt DateTime @default(now())
}

// Login sessions — powers the 60-minute inactivity timeout and the
// admin "active sessions" view (who is logged in, from where, since when).
model Session {
  id          Int       @id @default(autoincrement())
  sid         String    @unique
  username    String
  role        String    @default("user")
  ip          String    @default("")
  userAgent   String    @default("")
  loginAt     DateTime  @default(now())
  lastSeen    DateTime  @default(now())
  loggedOutAt DateTime?
}

// Inventory / stock — managed by admin and accountant; invoice lines can
// optionally draw from stock (deducted on save, restored by credit notes).
model InventoryItem {
  id              Int      @id @default(autoincrement())
  name            String
  sku             String   @default("")
  hsnCode         String   @default("")
  quantity        Float    @default(0)
  transitQuantity Float    @default(0) // quantity in DC transit (dispatched_but_not_billed)
  unit            String   @default("Nos")
  location        String   @default("")
  notes           String   @default("")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  movements       StockMovement[]
}

model StockMovement {
  id        Int           @id @default(autoincrement())
  itemId    Int
  item      InventoryItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  delta     Float         // +in / -out
  reason    String        @default("")
  byUsername String       @default("")
  createdAt DateTime      @default(now())
}

model Customer {
  id            Int       @id @default(autoincrement())
  name          String
  addressLines  String[]  @default([])
  contactPerson String    @default("")
  contactPhone  String    @default("")
  email         String    @default("")
  gstn          String    @default("")
  stateCode     String    @default("")
  createdAt     DateTime  @default(now())
  invoices      Invoice[]
  rmaTickets    RmaTicket[]
}

// ──────────────────────────────────────────────────────────────
// Invoice — the variable, per-document values entered in the form.
// ──────────────────────────────────────────────────────────────
model Invoice {
  id            Int      @id @default(autoincrement())
  invoiceNo     String   @unique
  seriesId      Int?     // which InvoiceSeries produced this number
  docType       String   @default("invoice") // invoice | credit-note | debit-note
  againstInvoiceNo String @default("") // CN/DN: the original invoice referenced
  invoiceDate   DateTime @default(now())

  // Document meta (overridable per invoice, defaulted from settings)
  title         String   @default("Commercial Invoice")
  copyType      String   @default("Original for Buyer")
  transportMode String   @default("By Road")
  poRefNo       String   @default("")
  paymentTerms  String   @default("Immediate.")

  // Buyer details (snapshot — invoice stays correct even if customer edited later)
  customerId        Int?
  customer          Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  buyerName         String
  buyerAddressLines String[]  @default([])
  buyerContactPerson String   @default("")
  buyerContactPhone String    @default("")
  buyerEmail        String    @default("")
  buyerGstn         String    @default("")
  buyerStateCode    String    @default("")

  // Tax mode
  taxMode  String  @default("intra") // "intra" => CGST+SGST, "inter" => IGST
  cgstRate Float   @default(9)
  sgstRate Float   @default(9)
  igstRate Float   @default(18)

  // Computed totals (stored as snapshot for fast listing & exact reprint)
  subTotal    Float  @default(0)
  cgstAmount  Float  @default(0)
  sgstAmount  Float  @default(0)
  igstAmount  Float  @default(0)
  roundOff    Float  @default(0)
  grandTotal  Float  @default(0)
  amountWords String @default("")

  // Presentation
  theme  String  @default("orange")
  notes  String  @default("")
  amountPaid Float @default(0) // settled via bank categorization (AR)
  status String  @default("issued") // issued | deleted (payment state derives from amountPaid)

  // Edit tracking
  editCount    Int       @default(0)
  lastEditedAt DateTime?

  items InvoiceItem[]
  edits InvoiceEdit[]
  deliveryChallans DeliveryChallan[]
  rmaTickets       RmaTicket[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Append-only edit history for an invoice (shown as the "edit log").
model InvoiceEdit {
  id        Int      @id @default(autoincrement())
  invoiceId Int
  invoice   Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  changedAt DateTime @default(now())
  summary   String
}

model InvoiceItem {
  id        Int     @id @default(autoincrement())
  invoiceId Int
  invoice   Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  slNo        Int
  description String
  hsnCode     String  @default("")
  qty         Float   @default(1)
  unit        String  @default("Nos")
  price       Float   @default(0)
  gstRate     Float   @default(18) // total GST % for this line (split into CGST/SGST or IGST)
  gstInclusive Boolean @default(false) // true => entered price already includes GST
  inventoryItemId Int? // optional stock link — deducts on save
  total       Float   @default(0)
}

// ──────────────────────────────────────────────────────────────
// PAYMENT TERMS — predefined dropdown options, admin-managed.
// Seeded with standard options on first boot.
// ──────────────────────────────────────────────────────────────
model PaymentTerm {
  id        Int      @id @default(autoincrement())
  label     String   @unique // e.g. "Net 30"
  active    Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
}

// ──────────────────────────────────────────────────────────────
// DELIVERY CHALLAN — generated from an invoice for dispatch.
// Inventory moves to transit state when DC is created.
// ──────────────────────────────────────────────────────────────
model DeliveryChallan {
  id        Int     @id @default(autoincrement())
  dcNo      String  @unique @default("") // DC-0001 …
  invoiceId Int?
  invoice   Invoice? @relation(fields: [invoiceId], references: [id], onDelete: SetNull)

  // Dispatch details
  transporterName  String @default("")
  vehicleNo        String @default("")
  ewayBillNo       String @default("")
  dispatchLocation String @default("")
  dispatchDate     String @default("") // yyyy-mm-dd

  // Customer snapshot
  buyerName        String @default("")
  buyerAddress     String @default("")

  status    String @default("open") // open | delivered | cancelled

  items     DeliveryChallanItem[]

  createdBy String   @default("")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model DeliveryChallanItem {
  id           Int             @id @default(autoincrement())
  challanId    Int
  challan      DeliveryChallan @relation(fields: [challanId], references: [id], onDelete: Cascade)
  description  String
  hsnCode      String  @default("")
  qty          Float   @default(1)
  unit         String  @default("Nos")
  inventoryItemId Int?
}

// ──────────────────────────────────────────────────────────────
// RMA — Return Material Assessment.
// Full lifecycle: initiation → evaluation → resolution.
// ──────────────────────────────────────────────────────────────
model RmaTicket {
  id         Int      @id @default(autoincrement())
  rmaNo      String   @unique @default("") // RMA-0001 …
  invoiceId  Int?
  invoice    Invoice? @relation(fields: [invoiceId], references: [id], onDelete: SetNull)
  customerId Int?
  customer   Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)

  status     String   @default("pending") // pending | under_inspection | replacement | repair | scrapped | closed

  // Evaluation notes
  qaFindings      String @default("")
  resolutionRoute String @default("") // replacement | repair | scrap

  // Linked outputs
  replacementStockNote String @default("")
  creditNoteId         Int?   @unique // if scrapped → linked credit note voucher
  creditNote           AccVoucher? @relation(fields: [creditNoteId], references: [id])

  items     RmaItem[]

  raisedBy  String   @default("")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model RmaItem {
  id           Int       @id @default(autoincrement())
  ticketId     Int
  ticket       RmaTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  description  String
  qty          Float     @default(1)
  unit         String    @default("Nos")
  issueDetails String    @default("")
  inventoryItemId Int?
}

// ──────────────────────────────────────────────────────────────
// BUSINESS ASSETS — standard (long-term) and demo (short-term).
// ──────────────────────────────────────────────────────────────
model BusinessAsset {
  id              Int       @id @default(autoincrement())
  name            String
  assetCode       String    @default("")
  assetType       String    @default("standard") // standard | demo
  category        String    @default("") // Laptop | Desktop | Vehicle | Demo Unit …
  description     String    @default("")
  purchaseDate    String    @default("") // yyyy-mm-dd
  cost            Float     @default(0)
  depRate         Float     @default(15) // % per annum (standard assets)
  status          String    @default("available") // available | allocated | in_demo | maintenance | disposed

  // Current custodian
  assignedEmployeeId Int?
  assignedEmployee   Employee? @relation(fields: [assignedEmployeeId], references: [id], onDelete: SetNull)

  history BusinessAssetHistory[]

  notes     String   @default("")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model BusinessAssetHistory {
  id         Int           @id @default(autoincrement())
  assetId    Int
  asset      BusinessAsset @relation(fields: [assetId], references: [id], onDelete: Cascade)
  action     String        @default("") // allocated | returned | sent_for_repair | disposed
  fromEmployeeId Int?
  toEmployeeId   Int?
  notes      String   @default("")
  byUsername String   @default("")
  createdAt  DateTime @default(now())
}

// ──────────────────────────────────────────────────────────────
// STAFF GOALS & CAREER DEVELOPMENT
// ──────────────────────────────────────────────────────────────
model StaffGoal {
  id          Int       @id @default(autoincrement())
  employeeId  Int
  employee    Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  title       String
  description String    @default("")
  kpis        String    @default("") // JSON array of KPI strings
  targetDate  String    @default("") // yyyy-mm-dd
  progress    Float     @default(0)  // 0–100 %
  evidenceUrl String    @default("") // data URL or file reference
  status      String    @default("active") // active | completed | cancelled
  assignedBy  String    @default("")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

// ──────────────────────────────────────────────────────────────
// STAFF FEEDBACK (anonymous internal suggestions loop)
// ──────────────────────────────────────────────────────────────
model StaffFeedback {
  id        Int      @id @default(autoincrement())
  category  String   @default("general") // suggestion | feedback | complaint | general
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

// ──────────────────────────────────────────────────────────────
// TASK DEADLINE CHANGE REQUESTS
// ──────────────────────────────────────────────────────────────
model TaskDeadlineRequest {
  id           Int       @id @default(autoincrement())
  taskId       Int
  task         StaffTask @relation(fields: [taskId], references: [id], onDelete: Cascade)
  employeeId   Int
  employee     Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  originalDate String    @default("") // yyyy-mm-dd (the date before the request)
  proposedDate String    // yyyy-mm-dd
  reason       String
  status       String    @default("pending") // pending | approved | rejected
  adminComment String    @default("")
  createdAt    DateTime  @default(now())
}

// ──────────────────────────────────────────────────────────────
// GEOFENCE ZONES — admin-configurable attendance locations
// ──────────────────────────────────────────────────────────────
model GeofenceZone {
  id        Int      @id @default(autoincrement())
  name      String   // "Head Office" | "Project Site A" …
  lat       Float
  lng       Float
  radiusM   Float    @default(200) // metres
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
}

// ──────────────────────────────────────────────────────────────
// PURCHASES MODULE — supplier register + purchase bills.
// A purchase bill stocks-in inventory (unless delivered direct to a
// customer site) and auto-posts a purchase voucher into the books:
// Dr Purchase + Dr GST Input / Cr Supplier (Sundry Creditors).
// Open AP is derived FIFO from the books (see openBills()), so bank
// reconciliation payments settle these bills automatically.
// ──────────────────────────────────────────────────────────────
model Supplier {
  id            Int      @id @default(autoincrement())
  name          String   @unique
  group         String   @default("") // supplier group / category (e.g. Electricals, Motors)
  contactPerson String   @default("")
  phone         String   @default("")
  altPhone      String   @default("")
  email         String   @default("")
  gstn          String   @default("")
  stateCode     String   @default("")
  addressLines  String[] @default([])
  notes         String   @default("")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  purchases     PurchaseBill[]
}

model PurchaseBill {
  id         Int      @id @default(autoincrement())
  refNo      String   @unique @default("") // internal PB-0001 …
  billNo     String   @default("")         // supplier's invoice / bill number
  billDate   String   @default("")         // yyyy-mm-dd
  supplierId Int
  supplier   Supplier @relation(fields: [supplierId], references: [id])

  // Tax (snapshot)
  taxMode    String @default("intra") // intra => CGST+SGST input, inter => IGST input
  subTotal   Float  @default(0)
  cgstAmount Float  @default(0)
  sgstAmount Float  @default(0)
  igstAmount Float  @default(0)
  grandTotal Float  @default(0)

  // Goods destination
  storeTo           String @default("warehouse") // warehouse (stock-in) | customer (direct delivery, no stock)
  warehouseLocation String @default("")          // where the goods are stored
  deliverTo         String @default("")          // customer / site when delivered direct

  notes     String @default("") // purchase notes
  status    String @default("open") // open | deleted
  voucherId Int?   // the posted books voucher (vtype purchase)
  createdBy String @default("")

  items PurchaseItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PurchaseItem {
  id     Int          @id @default(autoincrement())
  billId Int
  bill   PurchaseBill @relation(fields: [billId], references: [id], onDelete: Cascade)

  slNo            Int     @default(1)
  description     String
  hsnCode         String  @default("")
  qty             Float   @default(1)
  unit            String  @default("Nos")
  price           Float   @default(0) // per-unit purchase price (ex-GST)
  gstRate         Float   @default(18)
  inventoryItemId Int?    // linked stock item (stocked-in on save)
  addToStock      Boolean @default(true) // auto-create/match an inventory item by name
  notes           String  @default("")
  total           Float   @default(0)
}
