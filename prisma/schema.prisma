// Bharath Automation — Invoicing database schema
// Postgres on Railway. `prisma migrate deploy` runs on boot.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ──────────────────────────────────────────────────────────────
// Company settings — the "fixed components" of every invoice.
// Singleton row (id = 1). Edited in the Settings pane and reflected
// live across the dashboard, preview and all exports.
// ──────────────────────────────────────────────────────────────
model CompanySettings {
  id           Int      @id @default(1)

  companyName  String   @default("Bharath Automation")
  tagline      String   @default("")
  logoDataUrl  String?  // optional uploaded logo (data URL). Falls back to built-in mark.

  // Address & contact (the block that prints under the logo)
  addressLines String[] @default([])
  phones       String[] @default([])
  emails       String[] @default([])
  website      String   @default("")
  gstn         String   @default("")
  division     String   @default("")
  stateCode    String   @default("33") // for intra/inter-state GST detection (TN = 33)

  // Invoice document defaults
  invoiceTitle   String  @default("Commercial Invoice")
  invoiceCopy    String  @default("Original for Buyer")
  invoicePrefix  String  @default("BA/TR/PS-")
  nextInvoiceSeq Int     @default(22)

  // Tax defaults
  defaultCgst    Float @default(9)
  defaultSgst    Float @default(9)
  defaultIgst    Float @default(18)
  defaultGstRate Float @default(18) // default total GST % applied to new line items

  // Footer / terms
  paymentTerms String  @default("Immediate.")
  bankName     String  @default("")
  bankAccount  String  @default("")
  bankIfsc     String  @default("")
  bankBranch   String  @default("")
  footerNote   String  @default("E & O.E")
  signatory    String  @default("Authorized Signatory")
  signatureDataUrl String?
  termsNote    String  @default("Goods once sold will not be taken back. Subject to Coimbatore jurisdiction.")

  // Presentation
  defaultTheme String  @default("orange")
  currency     String  @default("INR")
  currencySymbol String @default("₹")

  // Login screen content (editable by admin, shown to everyone)
  loginNote   String  @default("")
  loginHeading String @default("Thirukural of the day")
  showLoginQuote Boolean @default(true)

  updatedAt DateTime @updatedAt
}

// App users (login accounts). Passwords are scrypt-hashed.
model User {
  id        Int       @id @default(autoincrement())
  username  String    @unique
  role      String    @default("user") // admin | user
  passHash  String
  createdAt DateTime  @default(now())
  employee  Employee?
}

// Staff / employee files
model Employee {
  id               Int       @id @default(autoincrement())
  userId           Int?      @unique
  user             User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  name             String
  dob              DateTime?
  address          String    @default("")
  phone            String    @default("")
  altPhone         String    @default("")
  bloodGroup       String    @default("")
  medicalCondition String    @default("")
  medication       String    @default("")
  emergencyName    String    @default("") // parent / guardian
  emergencyPhone   String    @default("")
  email            String    @default("")
  // documents — stored as image data URLs (<= 2MB each)
  aadharDoc    String?
  panDoc       String?
  licenseDoc   String?
  rcDoc        String?
  insuranceDoc String?
  // vehicle
  vehicleNo       String    @default("")
  insuranceExpiry DateTime?
  active          Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  attendance      Attendance[]
  leaves          LeaveRequest[]
  expenses        ExpenseClaim[]
  tasks           StaffTask[]
}

model Attendance {
  id          Int       @id @default(autoincrement())
  employeeId  Int
  employee    Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  date        String    // yyyy-mm-dd
  present     Boolean   @default(true)
  clockIn     DateTime?
  clockOut    DateTime?
  workSummary String    @default("") // mandatory brief of the day's work (on clock-out / full-day)
  manual      Boolean   @default(false) // true when marked as full-day without clock in/out

  @@unique([employeeId, date])
}

// Staff leave requests — staff raise, admin approves/rejects.
model LeaveRequest {
  id           Int      @id @default(autoincrement())
  employeeId   Int
  employee     Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  fromDate     String   // yyyy-mm-dd
  toDate       String   // yyyy-mm-dd
  reason       String   @default("")
  status       String   @default("pending") // pending | approved | rejected
  adminComment String   @default("")
  createdAt    DateTime @default(now())
}

// Staff expense claims (travel etc.) with an optional receipt image (<= 2MB).
model ExpenseClaim {
  id           Int      @id @default(autoincrement())
  employeeId   Int
  employee     Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  date         String   // yyyy-mm-dd
  category     String   @default("Travel")
  amount       Float    @default(0)
  description  String   @default("")
  receipt      String?  // image data URL, <= 2MB
  status       String   @default("pending") // pending | approved | rejected
  adminComment String   @default("")
  createdAt    DateTime @default(now())
}

// Tasks assigned by admin to a staff member.
model StaffTask {
  id           Int      @id @default(autoincrement())
  employeeId   Int
  employee     Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  title        String
  description  String   @default("")
  dueDate      String?  // yyyy-mm-dd
  status       String   @default("assigned") // assigned (yet to be taken) | processing | completed
  staffComment String   @default("")
  assignedBy   String   @default("Admin")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// Rotating login-screen quotes (Thirukkural). One is shown per day,
// deterministically, so every user sees the same quote that day.
model LoginQuote {
  id        Int      @id @default(autoincrement())
  text      String   // couplet — two lines separated by \n
  meaning   String   @default("")
  active    Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
}

// ──────────────────────────────────────────────────────────────
// Saved customers (optional reuse / autofill)
// ──────────────────────────────────────────────────────────────
// ──────────────────────────────────────────────────────────────
// Invoice number series. Multiple series can exist (e.g. per division
// or year); each keeps its own running sequence. The next number is
// auto-generated and never reused, even if an invoice is deleted.
// ──────────────────────────────────────────────────────────────
model InvoiceSeries {
  id        Int      @id @default(autoincrement())
  name      String   @default("Default")
  prefix    String   @default("BA/TR/PS-")
  nextSeq   Int      @default(1)
  padWidth  Int      @default(4)
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Customer {
  id            Int       @id @default(autoincrement())
  name          String
  addressLines  String[]  @default([])
  contactPerson String    @default("")
  contactPhone  String    @default("")
  email         String    @default("")
  gstn          String    @default("")
  stateCode     String    @default("")
  createdAt     DateTime  @default(now())
  invoices      Invoice[]
}

// ──────────────────────────────────────────────────────────────
// Invoice — the variable, per-document values entered in the form.
// ──────────────────────────────────────────────────────────────
model Invoice {
  id            Int      @id @default(autoincrement())
  invoiceNo     String   @unique
  seriesId      Int?     // which InvoiceSeries produced this number
  invoiceDate   DateTime @default(now())

  // Document meta (overridable per invoice, defaulted from settings)
  title         String   @default("Commercial Invoice")
  copyType      String   @default("Original for Buyer")
  transportMode String   @default("By Road")
  poRefNo       String   @default("")
  paymentTerms  String   @default("Immediate.")

  // Buyer details (snapshot — invoice stays correct even if customer edited later)
  customerId        Int?
  customer          Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  buyerName         String
  buyerAddressLines String[]  @default([])
  buyerContactPerson String   @default("")
  buyerContactPhone String    @default("")
  buyerEmail        String    @default("")
  buyerGstn         String    @default("")
  buyerStateCode    String    @default("")

  // Tax mode
  taxMode  String  @default("intra") // "intra" => CGST+SGST, "inter" => IGST
  cgstRate Float   @default(9)
  sgstRate Float   @default(9)
  igstRate Float   @default(18)

  // Computed totals (stored as snapshot for fast listing & exact reprint)
  subTotal    Float  @default(0)
  cgstAmount  Float  @default(0)
  sgstAmount  Float  @default(0)
  igstAmount  Float  @default(0)
  roundOff    Float  @default(0)
  grandTotal  Float  @default(0)
  amountWords String @default("")

  // Presentation
  theme  String  @default("orange")
  notes  String  @default("")
  status String  @default("draft") // draft | finalized | deleted

  // Edit tracking
  editCount    Int       @default(0)
  lastEditedAt DateTime?

  items InvoiceItem[]
  edits InvoiceEdit[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Append-only edit history for an invoice (shown as the "edit log").
model InvoiceEdit {
  id        Int      @id @default(autoincrement())
  invoiceId Int
  invoice   Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  changedAt DateTime @default(now())
  summary   String
}

model InvoiceItem {
  id        Int     @id @default(autoincrement())
  invoiceId Int
  invoice   Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  slNo        Int
  description String
  hsnCode     String  @default("")
  qty         Float   @default(1)
  unit        String  @default("Nos")
  price       Float   @default(0)
  gstRate     Float   @default(18) // total GST % for this line (split into CGST/SGST or IGST)
  gstInclusive Boolean @default(false) // true => entered price already includes GST
  total       Float   @default(0)
}
