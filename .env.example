# ── Database (Railway provides this automatically when you add a PostgreSQL plugin) ──
DATABASE_URL="postgresql://user:password@localhost:5432/bharath_invoicing?schema=public"

# ── Server ──
PORT=8080
NODE_ENV=development

# Sharing needs no config: WhatsApp opens wa.me and Email opens the user's
# default mail app (mailto:), with the invoice PDF downloaded to attach.

# ── Auth ──
# Secret used to sign login tokens — set a long random value on Railway.
AUTH_SECRET=change-this-to-a-long-random-string
# Login accounts:
#   Admin → username "Owner", password "Owner123"
#   Staff → username "Staff", password "Staff123"
# Usernames are fixed in code. Only the passwords can be overridden (optional):
# ADMIN_PASS=Owner123
# USER_PASS=Staff123
#
# NOTE: the old ADMIN_USER / USER_USER variables are no longer used. If your
# hosting still has them set (e.g. ADMIN_USER=Admin) you can delete them.
