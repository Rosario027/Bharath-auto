# ── Database (Railway provides this automatically when you add a PostgreSQL plugin) ──
DATABASE_URL="postgresql://user:password@localhost:5432/bharath_invoicing?schema=public"

# ── Server ──
PORT=8080
NODE_ENV=development

# ── Email sharing (optional — required only for "Send by Email") ──
# Use an app-password for Gmail (Google Account > Security > App passwords).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=prabhu.bharathautomation@gmail.com
SMTP_PASS=your-app-password-here
SMTP_FROM="Bharath Automation <prabhu.bharathautomation@gmail.com>"
